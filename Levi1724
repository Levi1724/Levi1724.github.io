<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SISTEMA QUANT - TERMINAL INSTITUCIONAL</title>
    
    <!-- Librerías de Producción vía CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <style>
        :root {
            --bg-main: #0d1117;
            --bg-card: #161b22;
            --border-color: #30363d;
            --text-main: #c9d1d9;
            --text-muted: #8b949e;
            
            /* Paleta Operativa Mate/Pastel Estricta CORREGIDA */
            --color-bullish: #1f8b8a;      /* Turquesa mate (Alcista / Longs) */
            --color-bearish: #8d5bde;      /* Púrpura mate (Bajista / Shorts) */
            --color-neutral: #bfa02c;      /* Amarillo mate (Neutro) */
            
            /* Estados del sistema */
            --status-active: #238636;       /* Verde */
            --status-inactive: #da3633;     /* Rojo Peligro */
            --status-default: #f0f6fc;      /* Blanco */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Consolas', 'Courier New', monospace;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            padding-top: 60px;
            overflow-x: hidden;
        }

        /* Barra de Navegación Fija Superior */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 60px;
            background-color: var(--bg-card);
            border-bottom: 2px solid var(--border-color);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .nav-container {
            display: flex;
            width: 100%;
            max-width: 1200px;
            justify-content: space-around;
        }

        .nav-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
            padding: 10px 20px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 3px solid transparent;
        }

        .nav-btn:hover {
            color: var(--text-main);
        }

        .nav-btn.active {
            color: var(--status-default);
            border-bottom: 3px solid var(--color-bullish);
            background-color: rgba(255, 255, 255, 0.03);
        }

        /* Contenedores de Vistas */
        .view-section {
            display: none;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
            animation: fadeIn 0.3s ease-in-out;
        }

        .view-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Estructuras Comunes */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 992px) {
            .grid-2 {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 20px;
            margin-bottom: 20px;
        }

        h2, h3, h4 {
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
        }

        /* Módulo 1: Inicio / Dashboard */
        .header-panel {
            text-align: center;
            background-color: rgba(22, 27, 34, 0.8);
            border: 1px solid var(--border-color);
            padding: 15px;
            margin-bottom: 20px;
        }

        .clock-digital {
            font-size: 24px;
            font-weight: bold;
            color: var(--status-default);
            margin-top: 5px;
        }

        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }

        /* Módulo 2: Operativa */
        .circle-indicator-container {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            align-items: center;
        }

        .circle-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background-color: var(--status-inactive);
            transition: background-color 0.3s ease;
        }

        .circle-dot.active {
            background-color: var(--status-active);
        }

        .trend-bar-wrapper {
            margin-bottom: 20px;
        }

        .trend-bar {
            display: flex;
            height: 20px;
            width: 100%;
            background-color: #222;
            border: 1px solid var(--border-color);
            border-radius: 2px;
            overflow: hidden;
        }

        .trend-slice {
            height: 100%;
            transition: width 0.3s ease;
        }

        .trend-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            margin-top: 4px;
            color: var(--text-muted);
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        button.btn-action {
            background-color: #21262d;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            cursor: pointer;
            font-weight: bold;
            text-transform: uppercase;
            border-radius: 4px;
        }

        button.btn-action:hover {
            background-color: #30363d;
            border-color: #8b949e;
        }

        /* Sub-bloques Horizontales con colorimetría estricta invertida */
        .sub-block-row {
            position: relative;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            padding: 10px;
            border: 1px solid var(--border-color);
            background-color: rgba(0,0,0,0.15);
            margin-bottom: 10px;
            border-radius: 4px;
            transition: background-color 0.3s ease;
        }

        .sub-block-row.bullish-bg { background-color: rgba(31, 139, 138, 0.12); } /* Turquesa */
        .sub-block-row.bearish-bg { background-color: rgba(141, 91, 222, 0.12); } /* Púrpura */
        .sub-block-row.neutral-bg { background-color: rgba(191, 160, 44, 0.12); } /* Amarillo */

        .overlay-expired {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(218, 54, 51, 0.85);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
            z-index: 10;
            border-radius: 4px;
            text-transform: uppercase;
        }

        select, input[type="text"], input[type="number"] {
            background-color: #0d1117;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 6px;
            border-radius: 4px;
            font-family: inherit;
        }

        /* Calculadora Cuantitativa */
        .form-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            margin-bottom: 12px;
            gap: 10px;
        }

        .output-field {
            background-color: #0d1117;
            padding: 6px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            min-height: 31px;
            display: flex;
            align-items: center;
            color: var(--status-default);
        }

        table.quant-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            font-size: 12px;
        }

        table.quant-table th, table.quant-table td {
            border: 1px solid var(--border-color);
            padding: 8px;
            text-align: left;
        }

        table.quant-table th {
            background-color: #1f242c;
            color: var(--text-muted);
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }

        /* Módulo 3: Registro */
        .ledger-container {
            max-height: 500px;
            overflow-y: auto;
            border: 1px solid var(--border-color);
            background-color: #0d1117;
            padding: 10px;
        }

        .ledger-row {
            padding: 8px;
            border-bottom: 1px solid var(--border-color);
            font-size: 12px;
            white-space: pre-wrap;
        }

        .delta-row {
            background-color: rgba(255, 255, 255, 0.04);
            color: var(--text-muted);
            font-style: italic;
        }

        .eod-row {
            background-color: rgba(191, 160, 44, 0.15);
            border-left: 4px solid var(--color-neutral);
        }

        /* Modales Nativos Estilizados */
        .modal-mask {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
        }

        .modal-mask.active {
            display: flex;
        }

        .modal-box {
            background-color: var(--bg-card);
            border: 2px solid var(--border-color);
            padding: 20px;
            border-radius: 4px;
            width: 90%;
            max-width: 500px;
            transition: border-color 0.3s ease;
        }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

        /* Vista Simplificada Toggle */
        .toggle-container {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <!-- MENÚ GLOBAL SUPERIOR -->
    <nav>
        <div class="nav-container">
            <button class="nav-btn active" onclick="switchTab('inicio')">Inicio</button>
            <button class="nav-btn" onclick="switchTab('operativa')">Operativa</button>
            <button class="nav-btn" onclick="switchTab('registro')">Registro</button>
            <button class="nav-btn" onclick="switchTab('resumen')">Resumen</button>
        </div>
    </nav>

    <!-- MÓDULO 1: INICIO -->
    <section id="view-inicio" class="view-section active">
        <div class="header-panel">
            <h2>Ratios de Operativa</h2>
            <div id="sys-date" style="color: var(--text-muted); font-size: 14px;">--/--/----</div>
            <div id="sys-clock" class="clock-digital">00:00:00</div>
        </div>
        
        <div class="grid-2">
            <div class="panel">
                <h3>Direccionalidad Operativa</h3>
                <div class="chart-container">
                    <canvas id="chartDonut"></canvas>
                </div>
            </div>
            <div class="panel">
                <h3>Curva de Capital / Rendimiento</h3>
                <div class="chart-container">
                    <canvas id="chartLine"></canvas>
                </div>
            </div>
        </div>
    </section>

    <!-- MÓDULO 2: OPERATIVA -->
    <section id="view-operativa" class="view-section">
        <div class="grid-2">
            
            <!-- Columna Izquierda: Matriz de Contexto -->
            <div class="panel">
                <h3>Matriz de Contexto Financiero</h3>
                
                <div class="circle-indicator-container">
                    <span style="font-size: 12px; color: var(--text-muted);">Sub-bloques:</span>
                    <div id="circle-dots-wrapper" style="display: flex; gap: 5px;"></div>
                </div>

                <div class="trend-bar-wrapper">
                    <div class="trend-bar" id="aggregate-trend-bar">
                        <!-- El orden está estrictamente ligado al CSS de colores -->
                        <div class="trend-slice" style="background-color: var(--color-bullish); width: 0%;"></div>
                        <div class="trend-slice" style="background-color: var(--color-bearish); width: 0%;"></div>
                        <div class="trend-slice" style="background-color: var(--color-neutral); width: 0%;"></div>
                    </div>
                    <div class="trend-labels">
                        <span id="label-alcista">A (Alcista): 0%</span>
                        <span id="label-bajista">B (Bajista): 0%</span>
                        <span id="label-neutral">N (Neutro): 0%</span>
                    </div>
                </div>

                <div class="btn-group">
                    <button class="btn-action" onclick="triggerModalAction('empezar')">Empezar</button>
                    <button class="btn-action" onclick="triggerModalAction('aumentar')">Aumentar</button>
                    <button class="btn-action" onclick="triggerModalAction('terminar')">Terminar</button>
                </div>

                <div id="sub-blocks-container">
                    <!-- Dinámico -->
                </div>
            </div>

            <!-- Columna Derecha: Calculadora Cuantitativa -->
            <div class="panel">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid var(--border-color); padding-bottom: 5px;">
                    <h3>Calculadora de Riesgo Estricto</h3>
                    <button class="btn-action" style="font-size: 11px; padding: 4px 8px; border-color: var(--status-inactive);" onclick="triggerModalAction('finalizar')">Finalizar</button>
                </div>

                <div class="form-group">
                    <label>Capital Inicial ($):</label>
                    <input type="number" id="calc-capital" value="10000" step="0.01" oninput="runCalculations()">
                </div>
                <div class="form-group">
                    <label>Dirección Operativa:</label>
                    <select id="calc-direction" onchange="runCalculations()">
                        <!-- Turquesa para Long / Púrpura para Short garantizado en JS -->
                        <option value="Long">Compra (Long / Alcista)</option>
                        <option value="Short">Venta (Short / Bajista)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Apalancamiento:</label>
                    <select id="calc-leverage" onchange="runCalculations()">
                        <option value="10">x10</option>
                        <option value="20">x20</option>
                        <option value="30">x30</option>
                        <option value="40">x40</option>
                        <option value="50">x50</option>
                        <option value="60">x60</option>
                        <option value="70">x70</option>
                        <option value="80">x80</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Resultado Apalancado:</label>
                    <div class="output-field" id="out-leveraged">0.0000</div>
                </div>
                <div class="form-group">
                    <label>Margen Entrada Efectivo (75%):</label>
                    <div class="output-field" id="out-margin">0.0000</div>
                </div>
                <div class="form-group">
                    <label>Comisiones Bróker (0.090%):</label>
                    <div class="output-field" id="out-commissions">0.0000</div>
                </div>
                <div class="form-group">
                    <label>Deslizamiento Real (0.02%):</label>
                    <div class="output-field" id="out-slippage">0.0000</div>
                </div>

                <h4 style="margin-top: 20px;">Invalidación y Estructura</h4>
                <div class="form-group">
                    <label>Precio de Entrada:</label>
                    <input type="number" id="calc-entry" value="100.0000" step="0.0001" oninput="runCalculations()">
                </div>
                <div class="form-group">
                    <label>Precio Invalidation (-0.10%):</label>
                    <div class="output-field" id="out-invalidation-price">0.0000</div>
                </div>
                <div class="form-group">
                    <label>Suma Pérdida Real Total:</label>
                    <div class="output-field" id="out-total-loss" style="color: var(--status-inactive);">0.0000</div>
                </div>
                <div class="form-group">
                    <label>Breakeven Real Absoluto:</label>
                    <div class="output-field" id="out-breakeven" style="color: var(--color-neutral);">0.0000</div>
                </div>

                <table class="quant-table">
                    <thead>
                        <tr>
                            <th>Hito %</th>
                            <th>Precio Proyectado</th>
                            <th>Ganancia Neta ($)</th>
                        </tr>
                    </thead>
                    <tbody id="projection-tbody">
                        <!-- Carga dinámica -->
                    </tbody>
                </table>

                <div class="checkbox-group">
                    <label><input type="checkbox" id="chk-narrative" onchange="logCheckboxChange('Narrativa de Proceso Aplicada', this)"> Narrativa de Proceso Aplicada</label>
                    <label><input type="checkbox" id="chk-rules" onchange="logCheckboxChange('Reglas Operativas Cumplidas', this)"> Reglas Operativas Cumplidas</label>
                </div>
            </div>
        </div>
    </section>

    <!-- MÓDULO 3: REGISTRO -->
    <section id="view-registro" class="view-section">
        <div class="toggle-container">
            <label style="font-size: 13px; color: var(--text-muted);">Estructura Visual de Datos:</label>
            <button class="btn-action" style="font-size: 11px; padding: 4px 10px;" id="btn-toggle-view" onclick="toggleViewMode()">Vista de Tabla Completa</button>
        </div>

        <div class="grid-2">
            <!-- Bloque 3.1: Bitácora de Actividad -->
            <div class="panel">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h3>Bitácora de Actividad Narrativa</h3>
                    <div>
                        <button class="btn-action" style="font-size: 11px; padding: 4px 8px;" onclick="openManualLogModal()">Agregar</button>
                        <button class="btn-action" style="font-size: 11px; padding: 4px 8px;" onclick="openEditLogModal()">Editar</button>
                    </div>
                </div>
                <div class="ledger-container" id="narrative-ledger">
                    <!-- Registros dinámicos invertidos -->
                </div>
            </div>

            <!-- Bloque 3.2: Base de Datos Cuantitativa -->
            <div class="panel" style="overflow-x: auto;">
                <h3>Base de Datos Cuantitativa Historizada</h3>
                <div id="quant-view-wrapper">
                    <!-- Render dinámico condicionado -->
                </div>
            </div>
        </div>
    </section>

    <!-- MÓDULO 4: RESUMEN Y SISTEMA -->
    <section id="view-resumen" class="view-section" style="text-align: center; padding-top: 50px;">
        <div class="panel" style="max-width: 600px; margin: 0 auto 30px auto;">
            <h3>Consolidación Operativa y Portabilidad</h3>
            <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 14px;">
                Generación asíncrona en paralelo de reportes analíticos institucionales. Al presionar el comando se compilarán los tres ledgers en un contenedor cifrado .ZIP local.
            </p>
            <button class="btn-action" style="padding: 15px 40px; font-size: 16px; border-color: var(--color-bullish);" onclick="exportAuditingPackage()">Extraer Registros</button>
        </div>

        <!-- NUEVO BLOQUE DE HARD RESET -->
        <div class="panel" style="max-width: 600px; margin: 0 auto; border-color: rgba(218, 54, 51, 0.4);">
            <h3 style="color: var(--status-inactive);">Mantenimiento: Restablecimiento del Sistema</h3>
            <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 14px;">
                PELIGRO: Este comando purgará completamente la base de datos local (matrices, registros y bitácoras), devolviendo la plataforma a su estado de fábrica inicial.
            </p>
            <button class="btn-action" style="padding: 10px 20px; font-size: 14px; border-color: var(--status-inactive); color: var(--status-inactive);" onclick="triggerModalAction('reset_1')">Hard Reset (Requiere Verificación)</button>
        </div>
    </section>

    <!-- MODAL CONFIRMACIONES INTEGRADO GENERAL -->
    <div class="modal-mask" id="modal-confirm">
        <div class="modal-box" id="modal-confirm-box">
            <h4 id="modal-confirm-title">Confirmación de Acción</h4>
            <p id="modal-confirm-msg" style="margin: 15px 0; font-size: 13px; color: var(--text-muted);"></p>
            <div class="modal-footer">
                <button class="btn-action" onclick="closeConfirmModal(false)">Cancelar</button>
                <button class="btn-action" id="modal-confirm-btn" style="border-color: var(--color-bullish);" onclick="closeConfirmModal(true)">Confirmar</button>
            </div>
        </div>
    </div>

    <!-- MODAL MANUAL NARRATIVA -->
    <div class="modal-mask" id="modal-manual-log">
        <div class="modal-box">
            <h4>Inyección Manual Ledger</h4>
            <div class="form-group" style="margin-top:15px;">
                <label>CUO Código:</label>
                <input type="text" id="manual-cuo" readonly>
            </div>
            <div class="form-group">
                <label>Descripción:</label>
                <input type="text" id="manual-desc" placeholder="Inserte flujo narrativo...">
            </div>
            <div class="modal-footer">
                <button class="btn-action" onclick="closeManualLogModal(false)">Cancelar</button>
                <button class="btn-action" style="border-color: var(--color-bullish);" onclick="closeManualLogModal(true)">Guardar</button>
            </div>
        </div>
    </div>

    <!-- MODAL EDITAR NARRATIVA -->
    <div class="modal-mask" id="modal-edit-log">
        <div class="modal-box">
            <h4>Modificación Segura de Bitácora</h4>
            <div class="form-group" style="margin-top:15px;">
                <label>Seleccionar CUO:</label>
                <select id="edit-cuo-select" onchange="onCuoSelectToEdit()"></select>
            </div>
            <div class="form-group">
                <label>Descripción:</label>
                <input type="text" id="edit-desc">
            </div>
            <div class="modal-footer">
                <button class="btn-action" onclick="closeEditLogModal(false)">Cancelar</button>
                <button class="btn-action" style="border-color: var(--color-bullish);" onclick="closeEditLogModal(true)">Actualizar</button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS DE MOTOR DE NEGOCIO -->
    <script>
        // Inicialización de Variables de Estado Global Único
        let state = {
            subBlocks: [],
            narrativeLog: [],
            quantLog: [],
            viewMode: 'completa',
            cuoCounter: 1
        };

        let donutChartInstance = null;
        let lineChartInstance = null;
        let pendingAction = null;
        let pendingBlockId = null;

        // Carga Inicial del Sistema
        window.addEventListener('DOMContentLoaded', () => {
            loadFromLocalStorage();
            initClock();
            initCharts();
            renderSubBlocks();
            runCalculations();
            renderNarrativeLedger();
            renderQuantLedger();
        });

        // Reloj y Fecha del Sistema Estilo Terminal
        function initClock() {
            const updateClock = () => {
                const now = new Date();
                document.getElementById('sys-date').textContent = now.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase();
                document.getElementById('sys-clock').textContent = now.toTimeString().split(' ')[0];
            };
            updateClock();
            setInterval(updateClock, 1000);
            
            // Intervalo para temporizadores de caducidad
            setInterval(processTimers, 1000);
        }

        // Navegación Fluida SPA
        function switchTab(tabId) {
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.view-section').forEach(sec => sec.classList.remove('active'));
            
            const selectedBtn = Array.from(document.querySelectorAll('.nav-btn')).find(btn => btn.textContent.toLowerCase() === tabId);
            if(selectedBtn) selectedBtn.classList.add('active');
            
            const targetSection = document.getElementById(`view-${tabId}`);
            if(targetSection) targetSection.classList.add('active');

            if(tabId === 'inicio') {
                updateChartsData();
            }
        }

        // Persistencia Segura LocalStorage
        function saveToLocalStorage() {
            localStorage.setItem('QUANT_STATE_V3', JSON.stringify(state));
        }

        function loadFromLocalStorage() {
            const saved = localStorage.getItem('QUANT_STATE_V3');
            if(saved) {
                try {
                    state = JSON.parse(saved);
                    if(state.narrativeLog.length > 0) {
                        const maxCuo = Math.max(...state.narrativeLog.map(l => parseInt(l.cuo) || 0));
                        state.cuoCounter = maxCuo + 1;
                    }
                } catch(e) {
                    console.error("Error al parsear estado persistido", e);
                }
            }
        }

        // Sistema Inverso de Logs Automáticos
        function pushNarrativeLog(description) {
            const now = new Date();
            const timeStr = now.toTimeString().split(' ')[0];
            const cuoStr = String(state.cuoCounter++).padStart(3, '0');
            
            state.narrativeLog.unshift({
                cuo: cuoStr,
                time: timeStr,
                desc: description
            });
            
            saveToLocalStorage();
            renderNarrativeLedger();
        }

        function renderNarrativeLedger() {
            const container = document.getElementById('narrative-ledger');
            container.innerHTML = '';
            state.narrativeLog.forEach(item => {
                const row = document.createElement('div');
                row.className = 'ledger-row';
                row.textContent = `${item.cuo} | ${item.time} | ${item.desc}`;
                container.appendChild(row);
            });
        }

        // Lógica de Modales de Intercepción Estilizados
        function triggerModalAction(action, blockId = null) {
            pendingAction = action;
            pendingBlockId = blockId;
            const modal = document.getElementById('modal-confirm');
            const modalBox = document.getElementById('modal-confirm-box');
            const btnConfirm = document.getElementById('modal-confirm-btn');
            const title = document.getElementById('modal-confirm-title');
            const msg = document.getElementById('modal-confirm-msg');

            // Resetear estilos del modal por defecto
            modalBox.style.borderColor = 'var(--border-color)';
            btnConfirm.style.borderColor = 'var(--color-bullish)';
            btnConfirm.style.color = 'var(--text-main)';

            if(action === 'empezar') {
                if(state.subBlocks.length > 0) {
                    alert("ALERTA MONITORIZADA: La sesión ya cuenta con flujos activos en ejecución.");
                    return;
                }
                title.textContent = "Inicializar Sesión Cuantitativa";
                msg.textContent = "¿Confirmas la activación estructural del primer sub-bloque analítico?";
            } else if(action === 'aumentar') {
                title.textContent = "Incrementar Vector de Flujo";
                msg.textContent = "¿Confirmas la inyección de una nueva temporalidad descendente en la matriz?";
            } else if(action === 'terminar') {
                title.textContent = "Reajuste de Emergencia del Sistema";
                msg.textContent = "¿Deseas limpiar las parametrizaciones contextuales y restablecer a posición Neutral de fábrica?";
            } else if(action === 'eliminar') {
                title.textContent = "Remoción de Sub-bloque";
                msg.textContent = `¿Confirmas la extirpación definitiva del sub-bloque referenciado?`;
            } else if(action === 'finalizar') {
                title.textContent = "Finalizar y Registrar Operación";
                msg.textContent = "¿Confirmas el registro cuantitativo en la bitácora y la purga de los datos de la calculadora?";
            } else if(action === 'reset_1') {
                // PRIMERA CONFIRMACIÓN DEL HARD RESET
                title.textContent = "ADVERTENCIA CRÍTICA DE SISTEMA (1/2)";
                msg.textContent = "Estás a punto de ELIMINAR TODOS LOS DATOS (Registros, Bitácora, Sub-bloques). ¿Deseas iniciar el proceso de purga?";
                modalBox.style.borderColor = 'var(--status-inactive)';
                btnConfirm.style.borderColor = 'var(--status-inactive)';
                btnConfirm.style.color = 'var(--status-inactive)';
            } else if(action === 'reset_2') {
                // SEGUNDA CONFIRMACIÓN DEL HARD RESET
                title.textContent = "CONFIRMACIÓN FINAL IRREVERSIBLE (2/2)";
                msg.textContent = "SE PERDERÁ TODO EL HISTORIAL OPERATIVO. ¿Estás absolutamente seguro de devolver el sistema al estado de fábrica inicial?";
                modalBox.style.borderColor = 'var(--status-inactive)';
                btnConfirm.style.borderColor = 'var(--status-inactive)';
                btnConfirm.style.color = 'var(--status-inactive)';
            }

            modal.classList.add('active');
        }

        function closeConfirmModal(confirmed) {
            document.getElementById('modal-confirm').classList.remove('active');
            
            // Si el usuario cancela, detenemos el flujo
            if(!confirmed) return;

            if(pendingAction === 'empezar') {
                createSubBlock();
                pushNarrativeLog("Sistema de monitoreo contextual inicializado.");
            } else if(pendingAction === 'aumentar') {
                createSubBlock();
                pushNarrativeLog("Nuevo sub-bloque de temporalidad inyectado de forma descendente.");
            } else if(pendingAction === 'terminar') {
                state.subBlocks.forEach(b => {
                    b.trend = 'Neutral';
                    b.velocity = 'Lento';
                    b.timeLeft = b.timeframeMinutes * 30 * 60;
                    b.expired = false;
                });
                pushNarrativeLog("Limpieza y restablecimiento global de sub-bloques ejecutada.");
                renderSubBlocks();
            } else if(pendingAction === 'eliminar' && pendingBlockId !== null) {
                state.subBlocks = state.subBlocks.filter(b => b.id !== pendingBlockId);
                pushNarrativeLog(`Sub-bloque residual removido de la pila.`);
                renderSubBlocks();
            } else if(pendingAction === 'finalizar') {
                finalizeSession();
            } else if(pendingAction === 'reset_1') {
                // Dispara la segunda confirmación tras una pequeña pausa visual
                setTimeout(() => { triggerModalAction('reset_2'); }, 300);
                return; // Evita el guardado normal debajo
            } else if(pendingAction === 'reset_2') {
                // Ejecuta la purga final y detiene el resto
                performHardReset();
                return; 
            }
            saveToLocalStorage();
        }

        // MOTOR DE HARD RESET
        function performHardReset() {
            // Vaciar memoria RAM
            state = {
                subBlocks: [],
                narrativeLog: [],
                quantLog: [],
                viewMode: 'completa',
                cuoCounter: 1
            };

            // Vaciar Disco Local
            localStorage.removeItem('QUANT_STATE_V3');

            // Restaurar Calculadora
            document.getElementById('calc-capital').value = '10000';
            document.getElementById('calc-entry').value = '100.0000';
            document.getElementById('calc-direction').value = 'Long';
            document.getElementById('calc-leverage').value = '10';
            document.getElementById('chk-narrative').checked = false;
            document.getElementById('chk-rules').checked = false;

            // Renderizar todo en blanco
            runCalculations();
            renderSubBlocks();
            renderNarrativeLedger();
            renderQuantLedger();
            updateChartsData();

            // Mover la vista a la página principal por higiene
            switchTab('inicio');
            
            alert("SISTEMA PURGADO. El estado de fábrica ha sido restablecido exitosamente.");
        }

        // Control y Operatividad de Sub-bloques Contextuales
        function createSubBlock() {
            const id = Date.now() + Math.random().toString(36).substr(2, 5);
            const defaultTf = 60; // 1 Hora por defecto
            state.subBlocks.push({
                id: id,
                timeframeMinutes: defaultTf,
                trend: 'Neutral',
                velocity: 'Lento',
                timeLeft: defaultTf * 30 * 60,
                expired: false
            });
            renderSubBlocks();
        }

        function renderSubBlocks() {
            const container = document.getElementById('sub-blocks-container');
            container.innerHTML = '';

            // Sincronización uno a uno de círculos superiores
            const dotsWrapper = document.getElementById('circle-dots-wrapper');
            dotsWrapper.innerHTML = '';

            state.subBlocks.forEach((block, index) => {
                // Crear círculo indicador superior
                const dot = document.createElement('div');
                dot.className = 'circle-dot';
                if(!block.expired && block.trend !== 'Neutral') dot.classList.add('active');
                dotsWrapper.appendChild(dot);

                // Crear Row Estructural
                const row = document.createElement('div');
                row.className = 'sub-block-row';
                
                // ASIGNACIÓN ESTRICTA DE COLOR EN MATRIZ CORREGIDA
                if(block.trend === 'Alcista') row.classList.add('bullish-bg'); // Turquesa garantizado
                if(block.trend === 'Bajista') row.classList.add('bearish-bg'); // Púrpura garantizado
                if(block.trend === 'Neutral') row.classList.add('neutral-bg'); // Amarillo

                // Botón Eliminar Fila
                const btnDel = document.createElement('button');
                btnDel.className = 'btn-action';
                btnDel.style.borderColor = 'var(--status-inactive)';
                btnDel.style.padding = '4px 8px';
                btnDel.style.fontSize = '11px';
                btnDel.textContent = 'X';
                btnDel.onclick = () => triggerModalAction('eliminar', block.id);
                row.appendChild(btnDel);

                // Desplegable Temporalidad
                const selTf = document.createElement('select');
                selTf.innerHTML = `
                    <option value="240" ${block.timeframeMinutes==240?'selected':''}>4 Horas</option>
                    <option value="120" ${block.timeframeMinutes==120?'selected':''}>2 Horas</option>
                    <option value="60" ${block.timeframeMinutes==60?'selected':''}>1 Hora</option>
                    <option value="45" ${block.timeframeMinutes==45?'selected':''}>45 Minutos</option>
                    <option value="30" ${block.timeframeMinutes==30?'selected':''}>30 Minutos</option>
                    <option value="15" ${block.timeframeMinutes==15?'selected':''}>15 Minutos</option>
                    <option value="10" ${block.timeframeMinutes==10?'selected':''}>10 Minutos</option>
                    <option value="5"  ${block.timeframeMinutes==5?'selected':''}>5 Minutos</option>
                    <option value="3"  ${block.timeframeMinutes==3?'selected':''}>3 Minutos</option>
                    <option value="1"  ${block.timeframeMinutes==1?'selected':''}>1 Minuto</option>
                `;
                selTf.onchange = (e) => {
                    const mins = parseInt(e.target.value);
                    block.timeframeMinutes = mins;
                    block.timeLeft = mins * 30 * 60;
                    block.expired = false;
                    pushNarrativeLog(`Mutación temporalidad a ${mins}M en sub-bloque.`);
                    renderSubBlocks();
                    saveToLocalStorage();
                };
                row.appendChild(selTf);

                // Desplegable Tendencia y Velocidad
                const selTrend = document.createElement('select');
                selTrend.innerHTML = `
                    <option value="Alcista_Rápido" ${block.trend==='Alcista'&&block.velocity==='Rápido'?'selected':''}>Alcista Rápido</option>
                    <option value="Alcista_Lento" ${block.trend==='Alcista'&&block.velocity==='Lento'?'selected':''}>Alcista Lento</option>
                    <option value="Neutral" ${block.trend==='Neutral'?'selected':''}>Neutral</option>
                    <option value="Bajista_Lento" ${block.trend==='Bajista'&&block.velocity==='Lento'?'selected':''}>Bajista Lento</option>
                    <option value="Bajista_Rápido" ${block.trend==='Bajista'&&block.velocity==='Rápido'?'selected':''}>Bajista Rápido</option>
                `;
                selTrend.onchange = (e) => {
                    const val = e.target.value;
                    if(val === 'Neutral') {
                        block.trend = 'Neutral';
                        block.velocity = 'Lento';
                    } else {
                        const parts = val.split('_');
                        block.trend = parts[0];
                        block.velocity = parts[1];
                    }
                    pushNarrativeLog(`Cambio de tendencia contextual a ${val} detectado.`);
                    renderSubBlocks();
                    saveToLocalStorage();
                };
                row.appendChild(selTrend);

                // Caja Matriz Direccional
                const dirBox = document.createElement('div');
                dirBox.style.fontWeight = 'bold';
                dirBox.style.minWidth = '40px';
                dirBox.style.textAlign = 'center';
                let arrow = '→';
                if(block.trend === 'Alcista') arrow = block.velocity === 'Rápido' ? '↑' : '↗';
                if(block.trend === 'Bajista') arrow = block.velocity === 'Rápido' ? '↓' : '↘';
                dirBox.textContent = arrow;
                row.appendChild(dirBox);

                // Caja del Temporizador Cuantitativo
                const timerBox = document.createElement('div');
                timerBox.style.fontSize = '12px';
                timerBox.style.color = 'var(--text-muted)';
                timerBox.textContent = formatSeconds(block.timeLeft);
                row.appendChild(timerBox);

