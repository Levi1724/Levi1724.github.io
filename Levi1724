                if(block.expired) {
                    const overlay = document.createElement('div');
                    overlay.className = 'overlay-expired';
                    overlay.textContent = 'Vencido';
                    overlay.onclick = () => {
                        block.expired = false;
                        block.trend = 'Neutral';
                        block.velocity = 'Lento';
                        block.timeLeft = block.timeframeMinutes * 30 * 60;
                        pushNarrativeLog("Sub-bloque vencido desbloqueado y reajustado.");
                        renderSubBlocks();
                        saveToLocalStorage();
                    };
                    row.appendChild(overlay);
                }

                container.appendChild(row);
            });

            calculateAggregateTrendBar();
        }

        // Gestión Avanzada de Relojes de Cuenta Regresiva
        function processTimers() {
            let directMutate = false;
            state.subBlocks.forEach(block => {
                if(!block.expired && block.timeLeft > 0) {
                    block.timeLeft--;
                    if(block.timeLeft <= 0) {
                        block.expired = true;
                        directMutate = true;
                        pushNarrativeLog("Ciclo temporal expirado. Sub-bloque bloqueado.");
                    }
                }
            });
            if(directMutate) {
                renderSubBlocks();
                saveToLocalStorage();
            } else {
                const container = document.getElementById('sub-blocks-container');
                if(container) {
                    const rows = container.querySelectorAll('.sub-block-row');
                    state.subBlocks.forEach((block, idx) => {
                        if(rows[idx] && !block.expired) {
                            const divs = rows[idx].querySelectorAll('div');
                            if(divs.length >= 2) {
                                divs[1].textContent = formatSeconds(block.timeLeft);
                            }
                        }
                    });
                }
            }
        }

        function formatSeconds(totalSecs) {
            const hrs = Math.floor(totalSecs / 3600);
            const mins = Math.floor((totalSecs % 3600) / 60);
            const secs = totalSecs % 60;
            return `${String(hrs).padStart(2,'0')}:${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
        }

        // Renderizado del Relleno de la Barra de Tendencia Dinámica Agregada
        function calculateAggregateTrendBar() {
            const total = state.subBlocks.length;
            if(total === 0) {
                document.getElementById('aggregate-trend-bar').children[0].style.width = '0%';
                document.getElementById('aggregate-trend-bar').children[1].style.width = '0%';
                document.getElementById('aggregate-trend-bar').children[2].style.width = '0%';
                document.getElementById('label-alcista').textContent = 'A (Alcista): 0%';
                document.getElementById('label-bajista').textContent = 'B (Bajista): 0%';
                document.getElementById('label-neutral').textContent = 'N (Neutro): 0%';
                return;
            }

            const alcistas = state.subBlocks.filter(b => b.trend === 'Alcista').length;
            const bajistas = state.subBlocks.filter(b => b.trend === 'Bajista').length;
            const neutrales = state.subBlocks.filter(b => b.trend === 'Neutral').length;

            const pAlc = (alcistas / total) * 100;
            const pBaj = (bajistas / total) * 100;
            const pNeu = (neutrales / total) * 100;

            const slices = document.getElementById('aggregate-trend-bar').children;
            // 0 es Turquesa (Alcista), 1 es Púrpura (Bajista), 2 es Amarillo (Neutral)
            slices[0].style.width = `${pAlc}%`;
            slices[1].style.width = `${pBaj}%`;
            slices[2].style.width = `${pNeu}%`;

            document.getElementById('label-alcista').textContent = `A (Alcista): ${pAlc.toFixed(1)}%`;
            document.getElementById('label-bajista').textContent = `B (Bajista): ${pBaj.toFixed(1)}%`;
            document.getElementById('label-neutral').textContent = `N (Neutro): ${pNeu.toFixed(1)}%`;
        }

        // MOTOR ARITMÉTICO DE LA CALCULADORA CUANTITATIVA FINANCIERA
        function runCalculations() {
            const capital = parseFloat(document.getElementById('calc-capital').value) || 0;
            const leverage = parseInt(document.getElementById('calc-leverage').value) || 10;
            const direction = document.getElementById('calc-direction').value;
            const entryPrice = parseFloat(document.getElementById('calc-entry').value) || 0;

            // Enlazar color del dropdown con la dirección operativa estrictamente
            const dirSelect = document.getElementById('calc-direction');
            if(direction === 'Long') {
                dirSelect.style.color = 'var(--color-bullish)';
            } else {
                dirSelect.style.color = 'var(--color-bearish)';
            }

            const leveragedResult = capital * leverage;
            const effectiveMargin = leveragedResult * 0.75;
            
            const brokerFees = effectiveMargin * 0.0009;
            const slippageCost = effectiveMargin * 0.0002; 
            const totalFriction = brokerFees + slippageCost;

            document.getElementById('out-leveraged').textContent = leveragedResult.toFixed(4);
            document.getElementById('out-margin').textContent = effectiveMargin.toFixed(4);
            document.getElementById('out-commissions').textContent = brokerFees.toFixed(4);
            document.getElementById('out-slippage').textContent = slippageCost.toFixed(4);

            if(entryPrice <= 0) {
                // Limpiar salidas si no hay precio de entrada
                document.getElementById('out-invalidation-price').textContent = '0.0000';
                document.getElementById('out-total-loss').textContent = '0.0000';
                document.getElementById('out-breakeven').textContent = '0.0000';
                document.getElementById('projection-tbody').innerHTML = '';
                return;
            }

            let invalidationPrice = 0;
            if(direction === 'Long') {
                invalidationPrice = entryPrice * (1 - 0.0010);
            } else {
                invalidationPrice = entryPrice * (1 + 0.0010);
            }
            
            const deltaLossCash = effectiveMargin * 0.0010;
            const totalRealLoss = deltaLossCash + totalFriction;

            document.getElementById('out-invalidation-price').textContent = invalidationPrice.toFixed(4);
            document.getElementById('out-total-loss').textContent = totalRealLoss.toFixed(4);

            const fractionMoveNeeded = (totalFriction / effectiveMargin) * entryPrice;
            let breakevenPrice = 0;
            if(direction === 'Long') {
                breakevenPrice = entryPrice + fractionMoveNeeded;
            } else {
                breakevenPrice = entryPrice - fractionMoveNeeded;
            }
            document.getElementById('out-breakeven').textContent = breakevenPrice.toFixed(4);

            const steps = [0.0010, 0.0020, 0.0030, 0.0040, 0.0050];
            const tbody = document.getElementById('projection-tbody');
            tbody.innerHTML = '';

            steps.forEach(step => {
                let projPrice = 0;
                if(direction === 'Long') {
                    projPrice = entryPrice * (1 + step);
                } else {
                    projPrice = entryPrice * (1 - step);
                }
                const grossGain = effectiveMargin * step;
                const netGain = grossGain - totalFriction;

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${(step * 100).toFixed(2)}%</td>
                    <td>${projPrice.toFixed(4)}</td>
                    <td style="color: ${netGain >= 0 ? 'var(--status-active)' : 'var(--status-inactive)'};">${netGain.toFixed(4)}</td>
                `;
                tbody.appendChild(row);
            });
        }

        // Automatización de Eventos de Captura de Checkbox en Bitácora
        function logCheckboxChange(label, element) {
            const status = element.checked ? "marcó como VERIFICADO" : "DESMARCÓ";
            pushNarrativeLog(`El operador ${status} la regla normativa: [${label}].`);
        }

        // Ejecución posterior a la confirmación de Finalizar
        function finalizeSession() {
            const capital = parseFloat(document.getElementById('calc-capital').value) || 0;
            const entryPrice = parseFloat(document.getElementById('calc-entry').value) || 0;
            
            if(capital > 0 && entryPrice === 0) {
                executeEODReconciliation(capital);
                return;
            }

            // Guardar Operación y Capturar Contexto de la Matriz (Temporalidades y Tendencias)
            saveCurrentQuantRecord();

            // Purga limpia de formulario
            document.getElementById('calc-entry').value = '';
            document.getElementById('chk-narrative').checked = false;
            document.getElementById('chk-rules').checked = false;
            runCalculations(); // Recalcula dejando en 0 los campos de abajo

            pushNarrativeLog("Formulario cuantitativo purgado. Operación y Contexto historizados.");
            // Actualizar gráficos al finalizar un trade
            updateChartsData();
        }

        // Lógica de Persistencia Histórica Compuesta por Filas Delta Diferenciales y Fotografía de Contexto
        function saveCurrentQuantRecord() {
            const capital = parseFloat(document.getElementById('calc-capital').value) || 0;
            const leverage = parseInt(document.getElementById('calc-leverage').value) || 10;
            const direction = document.getElementById('calc-direction').value;
            const entryPrice = parseFloat(document.getElementById('calc-entry').value) || 0;
            
            if(capital === 0 || entryPrice === 0) return;

            const effectiveMargin = (capital * leverage) * 0.75;
            const totalFriction = (effectiveMargin * 0.0009) + (effectiveMargin * 0.0002);

            // Capturar la Matriz de Temporalidades para inyectar en el Registro
            let contextArr = state.subBlocks.map(b => {
                let tfName = b.timeframeMinutes >= 60 ? (b.timeframeMinutes/60) + 'H' : b.timeframeMinutes + 'M';
                return `[${tfName}: ${b.trend}]`;
            });
            const contextSnapshot = contextArr.length > 0 ? contextArr.join(' ') : 'Sin Contexto Activo';

            const record = {
                type: 'TRADE',
                timestamp: new Date().toTimeString().split(' ')[0],
                capital: capital,
                leverage: leverage,
                direction: direction,
                entryPrice: entryPrice,
                friction: totalFriction,
                context: contextSnapshot
            };

            state.quantLog.push(record);
            saveToLocalStorage();
            renderQuantLedger();
        }

        // Detector de Cierre de Sesión Diario
        function executeEODReconciliation(finalCapital) {
            let totalGains = 0;
            let totalLosses = 0;

            state.quantLog.forEach((rec, idx) => {
                if(rec.type === 'TRADE' && idx > 0) {
                    const prev = state.quantLog[idx-1];
                    if(prev && prev.type === 'TRADE') {
                        const diff = rec.capital - prev.capital;
                        if(diff > 0) totalGains += diff;
                        else totalLosses += Math.abs(diff);
                    }
                }
            });

            const eodRecord = {
                type: 'EOD',
                timestamp: new Date().toTimeString().split(' ')[0],
                capitalRestante: finalCapital,
                gananciasAcumuladas: totalGains,
                perdidasAcumuladas: totalLosses
            };

            state.quantLog.push(eodRecord);
            pushNarrativeLog(`Fin de Sesión del Día procesado automáticamente. Balance Balance Finalizado.`);
            saveToLocalStorage();
            renderQuantLedger();
        }

        // Renderizado del Bloque 3.2 con Modos Alternables de Visualización y Columna de Contexto
        function toggleViewMode() {
            state.viewMode = state.viewMode === 'completa' ? 'simplificada' : 'completa';
            document.getElementById('btn-toggle-view').textContent = state.viewMode === 'completa' ? 'Vista de Tabla Completa' : 'Vista Simplificada';
            renderQuantLedger();
        }

        function renderQuantLedger() {
            const wrapper = document.getElementById('quant-view-wrapper');
            wrapper.innerHTML = '';

            if(state.quantLog.length === 0) {
                wrapper.innerHTML = '<p style="color:var(--text-muted);font-size:12px;">Sin registros cuantitativos en memoria.</p>';
                return;
            }

            const table = document.createElement('table');
            table.className = 'quant-table';

            if(state.viewMode === 'completa') {
                // Cabecera que incluye el Contexto
                table.innerHTML = `
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Tipo</th>
                            <th>Contexto Guardado</th>
                            <th>Cap. ($)</th>
                            <th>Apal.</th>
                            <th>Dir.</th>
                            <th>P. Entrada</th>
                            <th>Costos ($)</th>
                        </tr>
                    </thead>
                    <tbody id="quant-tbody"></tbody>
                `;
                wrapper.appendChild(table);
                const tbody = document.getElementById('quant-tbody');

                state.quantLog.forEach((rec, index) => {
                    // Filas Delta Diferenciales
                    if(index > 0 && rec.type === 'TRADE' && state.quantLog[index-1].type === 'TRADE') {
                        const prev = state.quantLog[index-1];
                        const capDiffAbs = rec.capital - prev.capital;
                        const capDiffPct = ((rec.capital - prev.capital) / prev.capital) * 100;
                        const pipDiff = (rec.entryPrice - prev.entryPrice) * 10000;
                        
                        const dRow = document.createElement('tr');
                        dRow.className = 'delta-row';
                        dRow.innerHTML = `
                            <td colspan="3">-> DELTA INTERMEDIO:</td>
                            <td style="color:${capDiffAbs>=0?'var(--status-active)':'var(--status-inactive)'};">
                                ${capDiffAbs >= 0 ? '+' : ''}${capDiffAbs.toFixed(2)} (${capDiffPct.toFixed(2)}%)
                            </td>
                            <td>--</td>
                            <td>--</td>
                            <td>${pipDiff >= 0 ? '+' : ''}${pipDiff.toFixed(1)} Pips</td>
                            <td>Absorbido: ${rec.friction.toFixed(4)}</td>
                        `;
                        tbody.appendChild(dRow);
                    }

                    const row = document.createElement('tr');
                    if(rec.type === 'EOD') {
                        row.className = 'eod-row';
                        row.innerHTML = `
                            <td>${rec.timestamp}</td>
                            <td><strong>CIERRE EOD</strong></td>
                            <td colspan="6">
                                Capital Final: $${rec.capitalRestante.toFixed(2)} | 
                                Ganancias Totales: $${rec.gananciasAcumuladas.toFixed(2)} | 
                                Pérdidas Totales: $${rec.perdidasAcumuladas.toFixed(2)}
                            </td>
                        `;
                    } else {
                        // REFORZANDO COLORES DE IMPRESIÓN EN TABLA
                        const dirColor = rec.direction === 'Long' ? 'var(--color-bullish)' : 'var(--color-bearish)';
                        const dirLabel = rec.direction === 'Long' ? 'Long (A)' : 'Short (B)';
                        
                        row.innerHTML = `
                            <td>${rec.timestamp}</td>
                            <td>TRADE</td>
                            <td style="font-size:10px; color:var(--text-muted);">${rec.context}</td>
                            <td>${rec.capital.toFixed(2)}</td>
                            <td>x${rec.leverage}</td>
                            <td style="color:${dirColor}; font-weight:bold;">${dirLabel}</td>
                            <td>${rec.entryPrice.toFixed(4)}</td>
                            <td>${rec.friction.toFixed(4)}</td>
                        `;
                    }
                    tbody.appendChild(row);
                });
            } else {
                table.innerHTML = `
                    <thead>
                        <tr>
                            <th>Indicador Cuantitativo</th>
                            <th>Valor Consolidado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Total Operaciones Ejecutadas</td>
                            <td>${state.quantLog.filter(r=>r.type==='TRADE').length}</td>
                        </tr>
                        <tr>
                            <td>Cierres de Sesión Registrados</td>
                            <td>${state.quantLog.filter(r=>r.type==='EOD').length}</td>
                        </tr>
                        <tr>
                            <td>Último Capital de Trabajo Reportado</td>
                            <td>$${state.quantLog.length > 0 ? (state.quantLog[state.quantLog.length-1].capital || state.quantLog[state.quantLog.length-1].capitalRestante || 0).toFixed(2) : '0.00'}</td>
                        </tr>
                    </tbody>
                `;
                wrapper.appendChild(table);
            }
        }

        // CONTROLES MANUALES CRUD SEGUROS PARA BITÁCORA NARRATIVA
        function openManualLogModal() {
            document.getElementById('manual-cuo').value = String(state.cuoCounter).padStart(3, '0');
            document.getElementById('manual-desc').value = '';
            document.getElementById('modal-manual-log').classList.add('active');
        }

        function closeManualLogModal(save) {
            document.getElementById('modal-manual-log').classList.remove('active');
            if(!save) return;
            const desc = document.getElementById('manual-desc').value.trim();
            if(!desc) return;
            pushNarrativeLog(`[MANUAL] ${desc}`);
        }

        function openEditLogModal() {
            const select = document.getElementById('edit-cuo-select');
            select.innerHTML = '';
            if(state.narrativeLog.length === 0) {
                alert("La bitácora analítica no contiene registros editables.");
                return;
            }
            state.narrativeLog.forEach(log => {
                const opt = document.createElement('option');
                opt.value = log.cuo;
                opt.textContent = `CUO ${log.cuo} (${log.time})`;
                select.appendChild(opt);
            });
            onCuoSelectToEdit();
            document.getElementById('modal-edit-log').classList.add('active');
        }

        function onCuoSelectToEdit() {
            const cuo = document.getElementById('edit-cuo-select').value;
            const target = state.narrativeLog.find(l => l.cuo === cuo);
            if(target) {
                document.getElementById('edit-desc').value = target.desc;
            }
        }

        function closeEditLogModal(save) {
            document.getElementById('modal-edit-log').classList.remove('active');
            if(!save) return;
            const cuo = document.getElementById('edit-cuo-select').value;
            const newDesc = document.getElementById('edit-desc').value.trim();
            
            const target = state.narrativeLog.find(l => l.cuo === cuo);
            if(target && newDesc) {
                target.desc = `[MODIFICADO SEGURIZADO] ${newDesc}`;
                pushNarrativeLog(`Modificación autorizada de la descripción del CUO ${cuo}.`);
                saveToLocalStorage();
                renderNarrativeLedger();
            }
        }

        // MOTOR INTEGRADO GRÁFICOS COMPUESTOS (CHART.JS)
        function initCharts() {
            const ctxDonut = document.getElementById('chartDonut').getContext('2d');
            donutChartInstance = new Chart(ctxDonut, {
                type: 'doughnut',
                data: {
                    // ETIQUETAS EXPLÍCITAS CON COLORES CORREGIDOS
                    labels: ['Compras (Alcista / Turquesa)', 'Ventas (Bajista / Púrpura)'],
                    datasets: [{
                        data: [50, 50],
                        // Índices: 0 = Turquesa (Longs/Alcista), 1 = Púrpura (Shorts/Bajista)
                        backgroundColor: ['#1f8b8a', '#8d5bde'], 
                        borderWidth: 1,
                        borderColor: '#30363d'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { labels: { color: '#c9d1d9', font: { family: 'monospace' } } } }
                }
            });

            const ctxLine = document.getElementById('chartLine').getContext('2d');
            lineChartInstance = new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: ['Inicio'],
                    datasets: [{
                        label: 'Evolución Saldo ($)',
                        data: [10000],
                        borderColor: '#1f8b8a', // Turquesa
                        backgroundColor: 'rgba(31, 139, 138, 0.05)', // Turquesa con opacidad
                        fill: true,
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { grid: { color: '#21262d' }, ticks: { color: '#8b949e' } },
                        y: { grid: { color: '#21262d' }, ticks: { color: '#8b949e' } }
                    },
                    plugins: { legend: { labels: { color: '#c9d1d9', font: { family: 'monospace' } } } }
                }
            });
            updateChartsData();
        }

        function updateChartsData() {
            if(!donutChartInstance || !lineChartInstance) return;

            const trades = state.quantLog.filter(r => r.type === 'TRADE');
            
            // Actualización del Gráfico de Direccionalidad basado en los registros reales
            let longs = trades.filter(t => t.direction === 'Long').length;
            let shorts = trades.filter(t => t.direction === 'Short').length;

            if(longs === 0 && shorts === 0) {
                donutChartInstance.data.datasets[0].data = [1, 1]; // Estado visual por defecto balanceado
            } else {
                // Índice 0 = Long (Turquesa), Índice 1 = Short (Púrpura)
                donutChartInstance.data.datasets[0].data = [longs, shorts];
            }
            donutChartInstance.update();

            // Actualización del Gráfico de Capital
            if(trades.length > 0) {
                let capPoints = [];
                let labels = [];
                trades.forEach((t, i) => {
                    capPoints.push(t.capital);
                    labels.push(`Tx ${i+1}`);
                });
                lineChartInstance.data.labels = labels;
                lineChartInstance.data.datasets[0].data = capPoints;
                lineChartInstance.update();
            } else {
                // Reset visual para el gráfico de líneas si se hace Hard Reset
                lineChartInstance.data.labels = ['Inicio'];
                lineChartInstance.data.datasets[0].data = [10000];
                lineChartInstance.update();
            }
        }

        // MÓDULO 4: MOTOR ASÍNCRONO DE PORTABILIDAD PDF Y DESCARGA ZIP COMPRIMIDA
        async function exportAuditingPackage() {
            pushNarrativeLog("Solicitud de extracción de auditoría procesada.");
            const { jsPDF } = window.jspdf;
            const zip = new JSZip();

            // --- DISEÑO EJECUTIVO DEL PDF 1 (BITÁCORA NARRATIVA) ---
            const doc1 = new jsPDF();
            doc1.setFont("courier", "bold");
            doc1.setFontSize(16);
            doc1.text("AUDITORIA COMPLEMENTARIA - LEDGER NARRATIVO", 15, 20);
            doc1.setFontSize(10);
            doc1.setFont("courier", "normal");
            let y1 = 35;
            doc1.text("CUO   | HORA     | DETALLE DE OPERACIÓN REGISTRADA", 15, y1);
            doc1.text("----------------------------------------------------------------------", 15, y1 + 5);
            y1 += 12;

            state.narrativeLog.forEach(l => {
                if(y1 > 280) { doc1.addPage(); y1 = 20; }
                const line = `${l.cuo}   | ${l.time} | ${l.desc}`;
                doc1.text(line, 15, y1);
                y1 += 8;
            });
            const blobPdf1 = doc1.output('blob');

            // --- DISEÑO EJECUTIVO DEL PDF 2 (REGISTRO CUANTITATIVO CON CONTEXTO) ---
            const doc2 = new jsPDF();
            doc2.setFont("courier", "bold");
            doc2.setFontSize(16);
            doc2.text("AUDITORIA FINANCIERA - REGISTRO CUANTITATIVO", 15, 20);
            doc2.setFontSize(9);
            doc2.setFont("courier", "normal");
            let y2 = 35;
            
            state.quantLog.forEach((rec, idx) => {
                if(y2 > 270) { doc2.addPage(); y2 = 20; }
                if(rec.type === 'TRADE') {
                    doc2.text(`TS: ${rec.timestamp} | DIR: ${rec.direction} | CTX: ${rec.context} | CAP: $${rec.capital.toFixed(2)} | ENTRADA: ${rec.entryPrice.toFixed(4)}`, 15, y2);
                } else {
                    doc2.text(`TS: ${rec.timestamp} | TIPO: EOD | CAP FINAL: $${rec.capitalRestante.toFixed(2)} | GANADO: $${rec.gananciasAcumuladas.toFixed(2)}`, 15, y2);
                }
                y2 += 10;
            });
            const blobPdf2 = doc2.output('blob');

            // --- DISEÑO EJECUTIVO DEL PDF 3 (REPORTE GERENCIAL RESUMEN) ---
            const doc3 = new jsPDF();
            doc3.setFont("courier", "bold");
            doc3.setFontSize(16);
            doc3.text("REPORTE GERENCIAL EJECUTIVO Y RATIOS", 15, 20);
            doc3.setFontSize(11);
            doc3.setFont("courier", "normal");
            doc3.text(`Fecha del Reporte de Auditoria: ${new Date().toLocaleDateString()}`, 15, 35);
            doc3.text(`Operaciones Consolidadas de la Sesión: ${state.quantLog.filter(r=>r.type==='TRADE').length}`, 15, 45);
            doc3.text("Estado del Sistema: ACTIVO / VERIFICADO", 15, 55);
            
            const blobPdf3 = doc3.output('blob');

            zip.file("PDF_1_Bitacora_Narrativa.pdf", blobPdf1);
            zip.file("PDF_2_Registro_Cuantitativo.pdf", blobPdf2);
            zip.file("PDF_3_Reporte_Ejecutivo_Ratios.pdf", blobPdf3);

            const content = await zip.generateAsync({type:"blob"});
            
            const link = document.createElement('a');
            link.href = URL.createObjectURL(content);
            link.download = `AUDITORIA_QUANT_${Date.now()}.zip`;
            link.click();
            
            pushNarrativeLog("Paquete de auditoría comprimido y extraído de forma exitosa.");
        }
    </script>
